{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "description": "Normal coding agent for everyday implementation, review, and debugging",
      "mode": "primary",
      "model": "openai/gpt-5.4",
      "reasoningEffort": "medium",
      "prompt": "{file:/home/tchi/.config/opencode/prompts/build-agent.md}",
      "permission": {
        "edit": "ask"
      },
      "tools": {
        "bash": true,
        "edit": true,
        "read": true,
        "write": true
      }
    },
    "plan": {
      "mode": "primary",
      "model": "openai/gpt-5.4",
      "prompt": "{file:/home/tchi/.config/opencode/prompts/plan-agent.md}",
      "reasoningEffort": "high",
      "permission": {
        "task": {
          "*": "deny",
          "plan-file": "allow"
        }
      },
      "tools": {
        "read": true,
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "plan-file": {
      "description": "Writes an existing plan to a planning document",
      "hidden": true,
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "prompt": "{file:/home/tchi/.config/opencode/prompts/plan-file-agent.md}",
      "permission": {
        "edit": "ask"
      },
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": false
      }
    },
    "gentle-orchestrator": {
      "description": "SDD workflow orchestrator responsible for coordination, delegation, synthesis, and workflow supervision. Does not perform substantial implementation work directly.",
      "mode": "primary",
      // "model": "openai/gpt-5.5", // Main model
      "model": "opencode-go/kimi-k2.6", // Backup model
      "reasoningEffort": "medium",
      "tools": {
        "delegate": true,
        "delegation_list": true,
        "delegation_read": true,
        "read": true
      },
      "permission": {
        "task": {
          "*": "deny",
          "sdd-apply": "allow",
          "sdd-archive": "allow",
          "sdd-design": "allow",
          "sdd-explore": "allow",
          "sdd-init": "allow",
          "sdd-onboard": "allow",
          "sdd-propose": "allow",
          "sdd-spec": "allow",
          "sdd-tasks": "allow",
          "sdd-verify": "allow"
        }
      },
      "prompt": "{file:/home/tchi/.config/opencode/prompts/sdd/sdd-orchestrator.md}"
    },
    "sdd-apply": {
      "description": "Implement code changes from task definitions",
      "hidden": true,
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-pro",
      "reasoningEffort": "high",
      "permission": {
        "edit": "ask",
        "write": "ask",
        "bash": "ask"
      },
      "prompt": "{file:/home/tchi/.config/opencode/prompts/sdd/sdd-apply.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "read": true,
        "write": true
      }
    },
    "sdd-archive": {
      "description": "Archive completed change artifacts",
      "hidden": true,
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "reasoningEffort": "medium",
      "prompt": "{file:/home/tchi/.config/opencode/prompts/sdd/sdd-archive.md}",
      "tools": {
        "bash": true,
        "read": true,
        "write": true
      }
    },
    "sdd-design": {
      "description": "Create technical design from proposals",
      "hidden": true,
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-pro",
      "reasoningEffort": "high",
      "prompt": "{file:/home/tchi/.config/opencode/prompts/sdd/sdd-design.md}",
      "tools": {
        "bash": true,
        "read": true,
        "write": true
      }
    },
    "sdd-explore": {
      "description": "Investigate codebase and think through ideas",
      "hidden": true,
      "mode": "subagent",
      "model": "opencode-go/qwen3.6-plus",
      "reasoningEffort": "high",
      "prompt": "{file:/home/tchi/.config/opencode/prompts/sdd/sdd-explore.md}",
      "tools": {
        "bash": true,
        "read": true,
        "browser_control": true,
        "chrome-figma": true,
        "playwright": true
      }
    },
    "sdd-init": {
      "description": "Bootstrap SDD context and project configuration",
      "hidden": true,
      "mode": "subagent",
      "model": "opencode-go/qwen3.6-plus",
      "reasoningEffort": "medium",
      "prompt": "{file:/home/tchi/.config/opencode/prompts/sdd/sdd-init.md}",
      "tools": {
        "bash": true,
        "read": true,
        "write": true
      }
    },
    "sdd-onboard": {
      "description": "Guide user through a complete SDD cycle using their real codebase",
      "hidden": true,
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini",
      "reasoningEffort": "medium",
      "prompt": "{file:/home/tchi/.config/opencode/prompts/sdd/sdd-onboard.md}",
      "tools": {
        "read": true,
        "write": true
      }
    },
    "sdd-propose": {
      "description": "Create change proposals from explorations",
      "hidden": true,
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-pro",
      "reasoningEffort": "high",
      "prompt": "{file:/home/tchi/.config/opencode/prompts/sdd/sdd-propose.md}",
      "tools": {
        "bash": true,
        "read": true,
        "write": true
      }
    },
    "sdd-spec": {
      "description": "Write detailed specifications from proposals",
      "hidden": true,
      "mode": "subagent",
      "model": "opencode-go/qwen3.6-plus",
      "reasoningEffort": "medium",
      "prompt": "{file:/home/tchi/.config/opencode/prompts/sdd/sdd-spec.md}",
      "tools": {
        "bash": true,
        "read": true,
        "write": true
      }
    },
    "sdd-tasks": {
      "description": "Break down specs and designs into implementation tasks",
      "hidden": true,
      "mode": "subagent",
      "model": "opencode-go/kimi-k2.6",
      "reasoningEffort": "medium",
      "prompt": "{file:/home/tchi/.config/opencode/prompts/sdd/sdd-tasks.md}",
      "tools": {
        "bash": true,
        "read": true,
        "write": true
      }
    },
    "sdd-verify": {
      "description": "Validate implementation against specs",
      "hidden": true,
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini",
      "reasoningEffort": "high",
      "prompt": "{file:/home/tchi/.config/opencode/prompts/sdd/sdd-verify.md}",
      "tools": {
        "bash": true,
        "read": true
      },
      "permission": {
        "bash": "ask"
      }
    }
  },
  "autoupdate": true,
  "mcp": {
    "Figma": {
      "enabled": true,
      "type": "local",
      "command": ["npx", "-y", "mcp-remote", "http://127.0.0.1:3845/mcp"]
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    "local-figma": {
      "enabled": true,
      "type": "local",
      "command": ["npx", "chrome-devtools-mcp@latest", "--browserUrl", "http://127.0.0.1:9222"]
    },
    "engram": {
      "command": ["/home/tchi/.local/bin/engram", "mcp", "--tools=agent"],
      "type": "local"
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "browser-control": {
      "type": "local",
      "enabled": true,
      "command": ["node", "/home/tchi/dev/tools/browser-control-mcp/mcp-server/dist/server.js"],
      "environment": {
        // It's ok to have this, it's only used locally from a temporary extension
        "EXTENSION_SECRET": "ff95e511-084f-4aeb-b5fa-57dc5c5a2e3f",
        "EXTENSION_PORT": "8089"
      }
    }
  },
  "permission": {
    "bash": {
      "git status": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow",
      "ls*": "allow",
      "pwd": "allow",
      "find*": "allow",
      "rg*": "allow",
      "grep*": "allow",
      "cat*": "allow",

      "pnpm test*": "ask",
      "pnpm lint*": "ask",
      "pnpm typecheck*": "ask",
      "pnpm build*": "ask",
      "npm test*": "ask",
      "npm run*": "ask",

      "git commit*": "ask",
      "git push*": "ask",
      "git rebase*": "ask",
      "git reset*": "ask",
      "git clean*": "ask",
      "rm*": "ask",

      "*": "ask"
    },
    "edit": "ask",
    "grep": "allow",
    "question": "allow",
    "read": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/credentials.json": "deny",
      "**/secrets/**": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "skill": {
      "*": "allow"
    }
  },
  "plugin": [
    "@mohak34/opencode-notifier@latest",
    "opencode-antigravity-auth@latest",
    "@tarquinen/opencode-dcp@latest",
    "@sillybit/opencode-plugin-everynotify"
  ]
}
